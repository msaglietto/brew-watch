---
import { env } from "cloudflare:workers";
import {
  getRecentChanges,
  brewUrl,
  type PackageKind,
  type ChangeCursor,
  type ChangeRow,
  type ChangeTypeFilter,
} from "../lib/db";

const kindParam = Astro.url.searchParams.get("kind");
const kind: PackageKind | "all" =
  kindParam === "formula" || kindParam === "cask" ? kindParam : "all";

const typeParam = Astro.url.searchParams.get("type");
const type: ChangeTypeFilter =
  typeParam === "new" || typeParam === "updated" ? typeParam : "all";

// Keyset cursor for the unified timeline: (detected_at, id).
// A single snapshot run stamps every change with the same detected_at, so id
// breaks the tie and the cursor partitions cleanly across runs.
const beforeTs = Astro.url.searchParams.get("before");
const beforeIdRaw = Astro.url.searchParams.get("before_id");
const beforeId = beforeIdRaw ? Number.parseInt(beforeIdRaw, 10) : Number.NaN;
const cursor: ChangeCursor | null =
  beforeTs && Number.isInteger(beforeId) ? { detected_at: beforeTs, id: beforeId } : null;

const LIMIT = 100;

const page = await getRecentChanges(env.DB, type, kind, {
  limit: LIMIT,
  cursor,
});

interface DayGroup {
  date: string;
  label: string;
  rows: ChangeRow[];
}

const MONTHS = [
  "Jan", "Feb", "Mar", "Apr", "May", "Jun",
  "Jul", "Aug", "Sep", "Oct", "Nov", "Dec",
];

function dayLabel(day: string): string {
  const [y, m, d] = day.split("-").map(Number);
  return `${MONTHS[m - 1]} ${d}, ${y}`;
}

// detected_at is a UTC ISO string; surface the time portion deterministically
// instead of relying on the runtime locale/timezone support.
function timeLabel(iso: string): string {
  return `${iso.slice(11, 16)} UTC`;
}

function groupByDay(rows: ChangeRow[]): DayGroup[] {
  const groups: DayGroup[] = [];
  for (const row of rows) {
    const day = row.detected_at.slice(0, 10);
    let group = groups[groups.length - 1];
    if (!group || group.date !== day) {
      group = { date: day, label: dayLabel(day), rows: [] };
      groups.push(group);
    }
    group.rows.push(row);
  }
  return groups;
}

const byDay = groupByDay(page.rows);

// Build a filter link that toggles one filter while preserving the other and
// the cursor. Passing undefined for a filter resets it to its default.
function filterLink(
  nextKind: PackageKind | "all" | undefined,
  nextType: ChangeTypeFilter | undefined,
): string {
  const params = new URLSearchParams();
  const effectiveKind = nextKind ?? kind;
  const effectiveType = nextType ?? type;
  if (effectiveKind !== "all") params.set("kind", effectiveKind);
  if (effectiveType !== "all") params.set("type", effectiveType);
  // Reset pagination when a filter changes.
  const qs = params.toString();
  return qs ? `/?${qs}` : "/";
}

// Build a pager link that preserves both filters. A null cursor returns to the
// newest page.
function pageLink(nextCursor: ChangeCursor | null): string {
  const params = new URLSearchParams();
  if (kind !== "all") params.set("kind", kind);
  if (type !== "all") params.set("type", type);
  if (nextCursor) {
    params.set("before", nextCursor.detected_at);
    params.set("before_id", String(nextCursor.id));
  }
  const qs = params.toString();
  return qs ? `/?${qs}` : "/";
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Brew Watch — new &amp; updated Homebrew packages</title>
    <meta
      name="description"
      content="A live timeline of new and updated Homebrew formulae and casks, refreshed hourly from formulae.brew.sh."
    />
    <meta property="og:title" content="Brew Watch" />
    <meta
      property="og:description"
      content="A live timeline of new and updated Homebrew formulae and casks, refreshed hourly."
    />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#faf7f2" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#161310" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        color-scheme: light dark;
        --bg: light-dark(#faf7f2, #161310);
        --text: light-dark(#2c261e, #ece4d8);
        --muted: light-dark(#7d7263, #9c8f7d);
        --line: light-dark(rgba(70, 55, 35, 0.14), rgba(236, 228, 216, 0.12));
        --line-soft: light-dark(rgba(70, 55, 35, 0.08), rgba(236, 228, 216, 0.07));
        --accent: light-dark(#9c5a14, #dfa055);
        --accent-soft: light-dark(rgba(156, 90, 20, 0.09), rgba(223, 160, 85, 0.12));
        --hover: light-dark(rgba(70, 55, 35, 0.05), rgba(236, 228, 216, 0.05));
        --sans: "Outfit", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --mono: "JetBrains Mono", ui-monospace, "SF Mono", Menlo, monospace;
      }
      * {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        max-width: 860px;
        margin: 0 auto;
        padding: 3rem 1.25rem 5rem;
        background: var(--bg);
        background-image: radial-gradient(
          ellipse 70% 24rem at 50% -6rem,
          var(--accent-soft),
          transparent
        );
        color: var(--text);
        font-family: var(--sans);
        line-height: 1.5;
      }
      a:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
        border-radius: 4px;
      }
      header h1 {
        font-size: 2.1rem;
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin: 0 0 0.35rem;
      }
      header h1 .tld {
        color: var(--accent);
      }
      p.subtitle {
        color: var(--muted);
        margin: 0;
        max-width: 56ch;
        text-wrap: balance;
      }
      p.subtitle a {
        color: inherit;
        text-decoration-color: var(--line);
        text-underline-offset: 3px;
        transition: color 200ms ease;
      }
      p.subtitle a:hover {
        color: var(--accent);
      }
      .filter-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem 2rem;
        margin: 2rem 0 2.5rem;
      }
      nav.filters {
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }
      nav.filters .filter-label {
        font-family: var(--mono);
        font-size: 0.68rem;
        letter-spacing: 0.08em;
        color: var(--muted);
        margin-right: 0.35rem;
      }
      nav.filters a {
        padding: 0.3rem 0.85rem;
        border: 1px solid var(--line);
        border-radius: 999px;
        text-decoration: none;
        color: var(--muted);
        font-size: 0.88rem;
        font-weight: 500;
        transition: color 200ms ease, background 200ms ease, border-color 200ms ease,
          transform 150ms ease;
      }
      nav.filters a:hover {
        color: var(--text);
        border-color: var(--muted);
        background: var(--hover);
      }
      nav.filters a:active {
        transform: scale(0.97);
      }
      nav.filters a.active {
        color: var(--accent);
        border-color: var(--accent);
        background: var(--accent-soft);
        font-weight: 600;
      }
      main section h2 {
        position: absolute;
        width: 1px;
        height: 1px;
        overflow: hidden;
        clip-path: inset(50%);
      }
      ul {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      li {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.55rem 0.75rem;
        margin: 0 -0.75rem;
        border-radius: 8px;
        border-bottom: 1px solid var(--line-soft);
        font-size: 0.95rem;
        transition: background 200ms ease;
      }
      li:hover {
        background: var(--hover);
      }
      li:last-child {
        border-bottom: none;
      }
      li a {
        color: inherit;
        font-family: var(--mono);
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
        transition: color 200ms ease;
      }
      li a:hover {
        color: var(--accent);
      }
      .kind-tag {
        color: var(--muted);
        font-size: 0.78rem;
        margin-left: 0.45rem;
      }
      .badge {
        display: inline-block;
        margin-left: 0.45rem;
        padding: 0.05rem 0.45rem;
        font-family: var(--mono);
        font-size: 0.6rem;
        font-weight: 600;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        border-radius: 4px;
        color: var(--accent);
        background: var(--accent-soft);
        border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
      }
      .line-main {
        display: flex;
        flex-direction: column;
        min-width: 0;
      }
      .line-title {
        display: inline;
      }
      .desc {
        display: block;
        color: var(--muted);
        font-size: 0.82rem;
        margin-top: 0.15rem;
      }
      .desc a.homepage {
        font-family: inherit;
        font-size: inherit;
        font-weight: 400;
        text-decoration: none;
      }
      .desc a.homepage:hover {
        color: var(--accent);
      }
      .line-meta {
        display: flex;
        gap: 0.75rem;
        align-items: baseline;
        white-space: nowrap;
      }
      .version {
        display: inline-flex;
        align-items: baseline;
        font-family: var(--mono);
        font-size: 0.82rem;
        color: var(--text);
      }
      .version .vnum {
        display: inline-block;
        max-width: 22ch;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        vertical-align: bottom;
        cursor: help;
      }
      .version .arrow {
        color: var(--accent);
        margin: 0 0.2rem;
        flex: none;
      }
      .when {
        color: var(--muted);
        font-family: var(--mono);
        font-size: 0.72rem;
      }
      .empty {
        margin-top: 1rem;
        padding: 2.5rem 1.5rem;
        text-align: center;
        border: 1px dashed var(--line);
        border-radius: 12px;
        color: var(--muted);
      }
      .empty .glyph {
        display: block;
        font-family: var(--mono);
        font-size: 1.1rem;
        color: var(--accent);
        margin-bottom: 0.5rem;
      }
      .empty p {
        margin: 0;
      }
      .empty .hint {
        font-size: 0.85rem;
        margin-top: 0.35rem;
      }
      .day-group {
        margin-bottom: 2.25rem;
      }
      .day-group:last-of-type {
        margin-bottom: 0;
      }
      .day-heading {
        position: sticky;
        top: 0;
        z-index: 1;
        background: var(--bg);
        font-family: var(--mono);
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        margin: 0.5rem 0 0.4rem;
        padding: 0.4rem 0 0.35rem;
        border-bottom: 1px solid var(--line);
      }
      .day-heading::before {
        content: "";
        display: inline-block;
        width: 0.5rem;
        height: 0.5rem;
        margin-right: 0.5rem;
        border-radius: 2px;
        background: var(--accent);
        vertical-align: baseline;
      }
      .day-group ul {
        margin-top: 0;
      }
      nav.pager {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        margin-top: 2rem;
        font-size: 0.9rem;
      }
      nav.pager a {
        padding: 0.4rem 1rem;
        border: 1px solid var(--line);
        border-radius: 8px;
        color: var(--text);
        font-weight: 500;
        text-decoration: none;
        transition: color 200ms ease, border-color 200ms ease, background 200ms ease,
          transform 150ms ease;
      }
      nav.pager a:hover {
        color: var(--accent);
        border-color: var(--accent);
        background: var(--accent-soft);
      }
      nav.pager a:active {
        transform: translateY(1px);
      }
      footer {
        margin-top: 4rem;
        padding-top: 1.25rem;
        border-top: 1px solid var(--line-soft);
        color: var(--muted);
        font-size: 0.8rem;
      }
      footer a {
        color: inherit;
        text-underline-offset: 3px;
        transition: color 200ms ease;
      }
      footer a:hover {
        color: var(--accent);
      }
      @media (max-width: 540px) {
        li {
          flex-direction: column;
          gap: 0.2rem;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <h1>Brew Watch<span class="tld">.</span></h1>
      <p class="subtitle">
        New and updated Homebrew formulae &amp; casks, tracked hourly from
        <a href="https://formulae.brew.sh/" target="_blank" rel="noopener">formulae.brew.sh</a>.
      </p>
    </header>

    <div class="filter-bar">
      <nav class="filters" aria-label="Kind filter">
        <span class="filter-label" aria-hidden="true">kind</span>
        <a href={filterLink("all", undefined)} class:list={{ active: kind === "all" }}>All</a>
        <a href={filterLink("formula", undefined)} class:list={{ active: kind === "formula" }}>Formulae</a>
        <a href={filterLink("cask", undefined)} class:list={{ active: kind === "cask" }}>Casks</a>
      </nav>
      <nav class="filters" aria-label="Change type filter">
        <span class="filter-label" aria-hidden="true">type</span>
        <a href={filterLink(undefined, "all")} class:list={{ active: type === "all" }}>All</a>
        <a href={filterLink(undefined, "new")} class:list={{ active: type === "new" }}>New</a>
        <a href={filterLink(undefined, "updated")} class:list={{ active: type === "updated" }}>Updated</a>
      </nav>
    </div>

    <main>
      <section>
        <h2>Changes</h2>
        {
          byDay.length === 0 ? (
            <div class="empty">
              <span class="glyph">$ brew watch</span>
              <p>
                {type === "new"
                  ? "No new packages detected yet."
                  : type === "updated"
                    ? "No updates detected yet."
                    : "No changes detected yet."}
              </p>
              <p class="hint">The snapshot runs every hour — check back soon.</p>
            </div>
          ) : (
            <>
              {byDay.map((group) => (
                <div class="day-group">
                  <h3 class="day-heading">{group.label}</h3>
                  <ul>
                    {group.rows.map((row) => (
                      <li>
                        <span class="line-main">
                          <span class="line-title">
                            <a href={brewUrl(row)} target="_blank" rel="noopener">
                              {row.name}
                            </a>
                            <span class="kind-tag">{row.kind}</span>
                            {row.change_type === "new" && <span class="badge">New</span>}
                          </span>
                          {row.description && (
                            <span class="desc">
                              {row.description}
                              {row.homepage && (
                                <> · <a class="homepage" href={row.homepage} target="_blank" rel="noopener">↗</a></>
                              )}
                            </span>
                          )}
                        </span>
                        <span class="line-meta">
                          <span class="version">
                            {row.change_type === "updated" ? (
                              <>
                                <span class="vnum" title={row.old_version}>{row.old_version}</span>
                                <span class="arrow">→</span>
                                <span class="vnum" title={row.new_version}>{row.new_version}</span>
                              </>
                            ) : (
                              <span class="vnum" title={row.new_version}>{row.new_version}</span>
                            )}
                          </span>
                          <span class="when">{timeLabel(row.detected_at)}</span>
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
              <nav class="pager">
                {cursor ? (
                  <a href={pageLink(null)}>← Newest</a>
                ) : (
                  <span />
                )}
                {page.nextCursor ? (
                  <a href={pageLink(page.nextCursor)}>Older →</a>
                ) : (
                  <span />
                )}
              </nav>
            </>
          )
        }
      </section>
    </main>

    <footer>
      Snapshots hourly from
      <a href="https://formulae.brew.sh/" target="_blank" rel="noopener">formulae.brew.sh</a> ·
      Runs on Cloudflare Workers &amp; D1
    </footer>
  </body>
</html>
